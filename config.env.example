# iFlow-to-IM Bridge Configuration
# Copy to ~/.iflow-to-im/config.env and edit

# Runtime backend: iflow | codex | auto
#   iflow (default) — uses iFlow CLI
#   codex  — uses @openai/codex-sdk (auth: codex auth login, or OPENAI_API_KEY)
#   auto   — tries iFlow first, falls back to Codex if not found
ITI_RUNTIME=iflow

# Enabled channels (comma-separated: telegram,discord,feishu,qq,wecom)
ITI_ENABLED_CHANNELS=telegram

# Default working directory for iFlow CLI sessions
ITI_DEFAULT_WORKDIR=/path/to/your/project

# Default model (optional — inherits from runtime's own default if not set)
# ITI_DEFAULT_MODEL=

# Default mode (code, plan, ask)
ITI_DEFAULT_MODE=code

# ── Codex auth (optional — only if not using `codex auth login`) ──
# Priority: ITI_CODEX_API_KEY > CODEX_API_KEY > OPENAI_API_KEY
# ITI_CODEX_API_KEY=
# ITI_CODEX_BASE_URL=

# ── Telegram ──
ITI_TG_BOT_TOKEN=your-telegram-bot-token
# Chat ID for authorization (at least one of CHAT_ID or ALLOWED_USERS is required)
# Get it: send a message to the bot, then visit https://api.telegram.org/botYOUR_TOKEN/getUpdates
ITI_TG_CHAT_ID=your-chat-id
# ITI_TG_ALLOWED_USERS=user_id_1,user_id_2

# ── Discord ──
# ITI_DISCORD_BOT_TOKEN=your-discord-bot-token
# ITI_DISCORD_ALLOWED_USERS=user_id_1,user_id_2
# ITI_DISCORD_ALLOWED_CHANNELS=channel_id_1
# ITI_DISCORD_ALLOWED_GUILDS=guild_id_1

# ── Feishu / Lark ──
# ITI_FEISHU_APP_ID=your-app-id
# ITI_FEISHU_APP_SECRET=your-app-secret
# ITI_FEISHU_DOMAIN=https://open.feishu.cn
# ITI_FEISHU_ALLOWED_USERS=user_id_1,user_id_2

# ── QQ ──
# Required: obtain from https://q.qq.com/qqbot/openclaw
# ITI_QQ_APP_ID=your-qq-app-id
# ITI_QQ_APP_SECRET=your-qq-app-secret
# Allowed users — comma-separated user_openid values (NOT QQ numbers)
# ITI_QQ_ALLOWED_USERS=openid_1,openid_2
# Image input — set to false if the underlying provider doesn't support image input
# ITI_QQ_IMAGE_ENABLED=true
# Max image size in MB (default 20)
# ITI_QQ_MAX_IMAGE_SIZE=20

# ── WeCom (企业微信) ──
# Required: obtain from 企业微信管理后台
# ITI_WECOM_BOT_ID=your-bot-id
# ITI_WECOM_BOT_SECRET=your-bot-secret
# Allowed users — comma-separated user IDs (leave empty for all users)
# ITI_WECOM_ALLOWED_USERS=user_id_1,user_id_2

# ── Permission ──
# Auto-approve all tool permission requests without user confirmation.
# Useful for channels that lack interactive permission UI (e.g. Feishu
# WebSocket long-connection mode, where there is no HTTP webhook to
# render clickable approve/deny buttons).
# ⚠️  Only enable this in trusted, access-controlled environments.
# ITI_AUTO_APPROVE=true